# ────────────────────────────────────────────────────────────────────────────
# Atlassian MCP Server — environment configuration
# Copy this file to .env and fill in the values for your deployment type.
# ────────────────────────────────────────────────────────────────────────────

# ── Jira ─────────────────────────────────────────────────────────────────────

# Your Jira instance URL (required).
# Cloud:       https://yourcompany.atlassian.net
# Server/DC:   https://jira.yourcompany.com
JIRA_URL=https://yourcompany.atlassian.net

# ── Jira Cloud authentication (use these OR the Server/DC token below) ────────

# Email address of the Jira user (Cloud only).
JIRA_USERNAME=you@yourcompany.com

# API token generated at https://id.atlassian.com/manage-profile/security/api-tokens
# (Cloud only — leave blank when using JIRA_PERSONAL_TOKEN).
JIRA_API_TOKEN=

# ── Jira Server / Data Center authentication ──────────────────────────────────

# Personal Access Token (Server/Data Center only).
# Generate via: Jira → Profile → Personal Access Tokens → Create token.
# Leave blank when using JIRA_USERNAME + JIRA_API_TOKEN for Cloud.
JIRA_PERSONAL_TOKEN=

# ── Confluence (optional) ─────────────────────────────────────────────────────

# Confluence instance URL.  Leave blank to disable Confluence tools.
CONFLUENCE_URL=https://yourcompany.atlassian.net/wiki

# Cloud: email address (same as JIRA_USERNAME for Atlassian Cloud).
CONFLUENCE_USERNAME=you@yourcompany.com

# Cloud: API token (same token as JIRA_API_TOKEN for Atlassian Cloud).
CONFLUENCE_API_TOKEN=

# ── Server settings ───────────────────────────────────────────────────────────

# Port the MCP server listens on inside the container.
# Must match the port mapping in docker-compose.yml.
MCP_PORT=9000

# Logging verbosity: -v (info), -vv (debug). Leave empty for warnings only.
MCP_LOG_LEVEL=-v
